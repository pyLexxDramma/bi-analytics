# Пример для opencode_web (скопируйте в .env рядом с этим каталогом). См. AI_INTEGRATION_GUIDE.md
# Не храните реальные пароли в Git.

ENABLE_SSH_TUNNEL=true
AI_SSH_HOST=<AI_SERVER_HOST>
AI_SSH_PORT=22
AI_SSH_USER=<SSH_USER>
AI_SSH_PASSWORD=<SSH_PASSWORD>
AI_OPENCODE_REMOTE_PORT=4096
AI_LOCAL_TUNNEL_PORT=4096
OPENCODE_URL=http://opencode:4096

# Правила тона/формата ответов (см. AI_ASSISTANT_RULES.md). По умолчанию в коде: /workspace/AI_ASSISTANT_RULES.md
# Локально на Windows: абсолютный путь к этому файлу в репозитории, например:
# AI_ASSISTANT_RULES_PATH=D:/path/to/opencode_web/AI_ASSISTANT_RULES.md

# Для основного BI (project_visualization_app): публичный URL чата в новой вкладке — в .env корня BI, не здесь:
# AI_ASSISTANT_URL=https://host:8501/
