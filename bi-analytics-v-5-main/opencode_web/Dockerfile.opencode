FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /root

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git bash python3 python3-pip python3-venv \
  && ln -sf /usr/bin/python3 /usr/bin/python \
  && python3 -m venv /opt/pytools \
  && /opt/pytools/bin/pip install --no-cache-dir --upgrade pip \
  && /opt/pytools/bin/pip install --no-cache-dir pandas matplotlib \
  && rm -rf /var/lib/apt/lists/*

# Установка OpenCode (официальный install one-liner)
RUN curl -fsSL https://opencode.ai/install | bash

ENV PATH="/root/.opencode/bin:${PATH}"
ENV PATH="/opt/pytools/bin:${PATH}"

RUN mkdir -p /root/.config/opencode /root/.local/share/opencode /root/.local/state /workspace

EXPOSE 4096

# Важно: в контейнере слушаем 0.0.0.0, иначе web-сервис не достучится
CMD ["bash", "-lc", "opencode serve --hostname 0.0.0.0 --port 4096"]