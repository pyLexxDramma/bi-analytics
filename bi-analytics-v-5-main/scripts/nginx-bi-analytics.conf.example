# Example site for ai.conall.ru (or a path). Place under sites-available and symlink to sites-enabled.
# Adjust server_name and TLS paths to match the server.

upstream bi_analytics_streamlit {
    server 127.0.0.1:8501;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name ai.conall.ru;
    # For Let's Encrypt certbot, keep HTTP first, then add SSL server block.

    location / {
        proxy_pass http://bi_analytics_streamlit;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }
}
